<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="me.n1ar4.jar.analyzer.core.mapper.AnnoMapper">
    <resultMap id="classMap" type="me.n1ar4.jar.analyzer.entity.ClassResult">
        <result column="class_name" property="className"/>
    </resultMap>
    <insert id="insertAnno" parameterType="AnnoEntity">
        INSERT INTO anno_table
        (anno_name, method_name, class_name, visible, jar_id)
        VALUES
        <foreach collection="list" separator="," item="item">
            (#{item.annoName}, #{item.methodName}, #{item.className}, #{item.visible}, #{item.jarId})
        </foreach>
    </insert>
    <select id="selectAnnoByClassName">
        SELECT DISTINCT anno_name
        FROM anno_table
        WHERE class_name = #{className}
    </select>
    <select id="selectAnnoByClassAndMethod">
        SELECT DISTINCT anno_name
        FROM anno_table
        WHERE class_name = #{className} AND method_name = #{methodName}
    </select>

    <!--
        Batch fetch every method-level annotation row for the given set
        of classes in one round trip. The IN list is built via
        parameterized #{} placeholders so no concatenation /
        injection is possible. Used by SPEL search to defeat the
        per-method N+1 pattern.
    -->
    <resultMap id="annoEntityMap" type="me.n1ar4.jar.analyzer.entity.AnnoEntity">
        <result column="anno_name" property="annoName"/>
        <result column="method_name" property="methodName"/>
        <result column="class_name" property="className"/>
    </resultMap>
    <select id="selectMethodAnnoByClasses" resultMap="annoEntityMap">
        SELECT DISTINCT anno_name, method_name, class_name
        FROM anno_table
        WHERE method_name IS NOT NULL
        AND class_name IN
        <foreach collection="classNames" item="cn" open="(" separator="," close=")">
            #{cn}
        </foreach>
    </select>

    <select id="selectClassByAnnoLike" resultMap="classMap">
        SELECT DISTINCT class_name
        FROM anno_table
        WHERE anno_name LIKE #{annoPattern} AND method_name IS NULL
    </select>
</mapper>